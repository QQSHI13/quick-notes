{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quick Notes",
  "version": "1.0.0",
  "identifier": "com.qq.quicknotes",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Quick Notes",
        "width": 700,
        "height": 550,
        "minWidth": 450,
        "minHeight": 350,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "skipTaskbar": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
