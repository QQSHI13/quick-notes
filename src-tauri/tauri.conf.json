{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quick Notes",
  "version": "1.0.12",
  "identifier": "com.qq.quicknotes",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Quick Notes",
        "width": 700,
        "height": 550,
        "minWidth": 450,
        "minHeight": 350,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "skipTaskbar": false,
        "center": true,
        "visible": true,
        "resizable": true,
        "maximizable": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' 'unsafe-inline' https://cdn.jsdelivr.net",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: https:",
        "connect-src": "'self'"
      }
    },
    "trayIcon": null
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "Productivity",
    "shortDescription": "Quick Notes - A lightweight note-taking app",
    "longDescription": "A fast, lightweight desktop note-taking application with global hotkey support, markdown editing, and system tray integration."
  }
}
